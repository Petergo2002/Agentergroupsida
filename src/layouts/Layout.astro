---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { SITE_DESCRIPTION, SITE_NAME } from '../data/site';

interface Props {
	title?: string;
	description?: string;
	canonicalPath?: string;
	alternateLinks?: Array<{ href: string; hreflang: string }>;
	structuredData?: Record<string, unknown> | Record<string, unknown>[];
	lang?: 'en' | 'sv';
}

const { 
	title = "AI chatbot för företag i Sverige | AgenterGroup",
	description = SITE_DESCRIPTION,
	canonicalPath = "/",
	alternateLinks = [],
	structuredData = [],
	lang = 'en'
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "";
const canonicalUrl = `${siteUrl}${canonicalPath}`;
const normalizedAlternateLinks = alternateLinks.map((link) => ({
	...link,
	href: link.href.startsWith("http") ? link.href : `${siteUrl}${link.href}`,
}));
const logoUrl = `${siteUrl}/2.svgfavicon.svg`;
const pageStructuredData = Array.isArray(structuredData) ? structuredData : [structuredData];
const allStructuredData = [
	{
		"@context": "https://schema.org",
		"@type": "Organization",
		name: SITE_NAME,
		url: siteUrl,
		logo: logoUrl,
		email: "info@agentergroup.com",
		contactPoint: [
			{
				"@type": "ContactPoint",
				email: "info@agentergroup.com",
				contactType: "sales",
				availableLanguage: ["sv-SE", "en-US"],
			},
		],
	},
	{
		"@context": "https://schema.org",
		"@type": "WebSite",
		name: SITE_NAME,
		url: siteUrl,
		inLanguage: lang === 'sv' ? "sv-SE" : "en-US",
	},
	...pageStructuredData,
].filter(Boolean);
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover, interactive-widget=resizes-content" />
		<link rel="icon" type="image/svg+xml" href="/2.svgfavicon.svg" />
		<link rel="shortcut icon" type="image/svg+xml" href="/2.svgfavicon.svg" />
		<link rel="canonical" href={canonicalUrl} />
		{normalizedAlternateLinks.map((link) => (
			<link rel="alternate" hreflang={link.hreflang} href={link.href} />
		))}
		<meta name="generator" content={Astro.generator} />
		<meta name="theme-color" content="#ffffff" />
		
		<!-- SEO -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:site_name" content={SITE_NAME} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:locale" content={lang === 'sv' ? "sv_SE" : "en_US"} />
		<meta property="og:image" content={logoUrl} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={logoUrl} />
		
		<!-- Fonts: Instrument Sans -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Instrument+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600;1,700&display=swap" rel="stylesheet">
		
		<!-- AgenterGroup Widget -->
		<script is:inline>
			const viewportMeta = document.querySelector('meta[name="viewport"]');
			const baseViewport =
				"width=device-width, initial-scale=1, viewport-fit=cover, interactive-widget=resizes-content";
			const isTouchAppleDevice =
				/iPhone|iPad|iPod/.test(navigator.userAgent) ||
				(navigator.userAgent.includes("Mac") && navigator.maxTouchPoints > 1);

			if (viewportMeta && isTouchAppleDevice) {
				viewportMeta.setAttribute("content", `${baseViewport}, maximum-scale=1`);
			}
		</script>
		<script is:inline>
			window.AG_WIDGET_API_URL = "https://dashboard.agentergroup.com";
			window.openAgenter = () => {
				if (window.AgenterWidget) {
					window.AgenterWidget.open();
				} else {
					const bubble = document.querySelector('.ag-widget-bubble');
					if (bubble) bubble.click();
				}
			};
		</script>
		<script is:inline src="https://widget.agentergroup.com/loader.js" data-widget="wgt_25be27bca2764d3eee"></script>
		{allStructuredData.length > 0 && (
			<script is:inline type="application/ld+json" set:html={JSON.stringify(allStructuredData)} />
		)}
	</head>
	<body class="bg-white text-slate-800 font-['Instrument_Sans',sans-serif] antialiased">
		
		<Navbar lang={lang} />
		<main class="relative z-10 w-full overflow-x-clip min-h-screen">
			<slot />
		</main>
		<Footer lang={lang} />
		
	</body>
</html>
