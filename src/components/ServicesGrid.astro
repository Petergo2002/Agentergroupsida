---
interface Props {
  lang?: 'en' | 'sv';
}
const { lang = 'en' } = Astro.props;

const copy = {
  label: lang === 'sv' ? 'Våra Tjänster' : 'Services',
  sectionTitle: lang === 'sv' ? 'Allt du behöver för att lansera själv' : 'Everything you need to launch it yourself',
  sectionSubtitle: lang === 'sv' 
    ? 'Skapa AI-agenten, träna den på ert innehåll, publicera den på hemsidan och koppla flöden för kundtjänst, leadkvalificering och mötesbokning.' 
    : 'Create the AI agent, train it on your content, publish it on your website, and connect flows for support, lead qualification, and meeting booking.',
  services: [
    {
      title: lang === 'sv' ? 'AI agent på hemsidan' : 'Website AI agent',
      description: lang === 'sv' ? 'Skapa en AI agent, lägg in den på hemsidan och låt den svara på frågor, samla kontaktuppgifter, kvalificera leads och boka möten.' : 'Create an AI agent, add it to your website, and let it answer questions, capture contact details, qualify leads, and book meetings.',
      icon: '<svg class="w-8 h-8 text-white/60 group-hover:text-brand-orange transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>',
    },
    {
      title: lang === 'sv' ? 'AI-kundtjänst och support' : 'AI customer service',
      description: lang === 'sv' ? 'Ladda upp er FAQ, dokument och webbinnehåll. AI-agenten lär sig era svar och kan lämna över ärenden när en människa behövs.' : 'Upload your FAQ, documents, and website content. The AI agent learns your answers and can hand off cases when a human is needed.',
      icon: '<svg class="w-8 h-8 text-white/60 group-hover:text-brand-orange transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>',
    },
    {
      title: lang === 'sv' ? 'Agentbyggare och integrationer' : 'Agent builder and integrations',
      description: lang === 'sv' ? 'Bygg fler AI-agenter i plattformen och koppla dem till CRM, kalender, e-post, dokument och interna flöden när agenten ska göra mer.' : 'Build more AI agents in the platform and connect them to CRM, calendar, email, documents, and internal workflows when the agent needs to do more.',
      icon: '<svg class="w-8 h-8 text-white/60 group-hover:text-brand-orange transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z"></path></svg>',
    }
  ]
};
---

<section id="services" class="scroll-scene relative bg-[#050505] text-white py-20 sm:py-32 lg:py-40 px-6">
  <!-- Elegant fading accent line divider -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-5xl h-px bg-gradient-to-r from-transparent via-white/[0.08] to-transparent z-10"></div>
  
  <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px] bg-[radial-gradient(circle_at_top,_rgba(255,92,0,0.03),_transparent_75%)]"></div>
  <div class="glow-dark-bottom-right"></div>

  <div class="mx-auto w-full max-w-7xl relative z-10">
    <!-- Header -->
    <div class="mb-12 grid gap-8 text-left sm:mb-16 lg:mb-20 lg:grid-cols-[minmax(0,0.95fr)_minmax(20rem,0.65fr)] lg:items-end">
      <div>
        <div class="mb-6 inline-flex items-center gap-3 rounded-full border border-white/10 bg-white/5 px-3 py-1 text-[8px] font-bold uppercase tracking-[0.28em] text-white/20 sm:mb-8 sm:text-[9px] sm:tracking-[0.4em]">
          {copy.label}
        </div>
        <h2 class="max-w-[15ch] text-[clamp(2.25rem,6vw,4.5rem)] font-medium leading-[1.0] tracking-[-0.04em] text-white/90">
          {copy.sectionTitle}
        </h2>
      </div>
      <p class="max-w-xl text-sm font-medium leading-relaxed text-white/40 sm:text-base md:text-[17px] lg:text-lg">
        {copy.sectionSubtitle}
      </p>
    </div>
    
    <!-- Services Grid -->
    <div class="grid gap-4 md:grid-cols-3 lg:gap-5">
      {copy.services.map((service) => (
        <article class="group relative flex min-h-[22rem] sm:min-h-[26rem] flex-col overflow-hidden rounded-[1.5rem] border border-white/[0.03] bg-[#0F0F0F] p-6 sm:p-8 lg:p-9 transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] hover:-translate-y-1.5 hover:border-brand-orange/20 hover:shadow-[0_20px_50px_rgba(223,80,7,0.03)] hover:bg-[#121212]">
          <!-- Icon -->
          <div class="mb-8 p-3 rounded-xl bg-white/[0.02] border border-white/[0.04] inline-flex w-fit group-hover:bg-brand-orange/5 group-hover:border-brand-orange/20 transition-all duration-300" set:html={service.icon} />
          
          <!-- Content -->
          <div class="mt-auto">
            <h3 class="mb-3 text-[22px] font-bold tracking-tight text-white/90 sm:text-[24px]">
              {service.title}
            </h3>
            
            <p class="text-[15px] font-medium leading-relaxed text-white/40">
              {service.description}
            </p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
