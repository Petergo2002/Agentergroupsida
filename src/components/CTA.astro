<section
  id="cta"
  class="scroll-scene relative border-t border-white/[0.03] py-20 sm:py-24 lg:py-28"
  data-scroll-scene
  data-scene-kind="cta"
  data-scene-mode="soft"
>
  <div class="scene-divider" data-scene-divider></div>
  <div class="pointer-events-none absolute inset-x-0 top-8 h-40 bg-[radial-gradient(circle_at_center,_rgba(255,92,0,0.08),_transparent_70%)]" data-scene-backdrop></div>
  <div class="mx-auto w-full max-w-7xl px-6 sm:px-8 lg:px-10" data-scene-stage>
    <div class="mx-auto max-w-5xl text-center" data-scene-content>
      <div>
        <div class="mb-6 inline-flex items-center gap-3 rounded-full border border-white/10 bg-white/5 px-3 py-1 text-[9px] font-bold uppercase tracking-[0.4em] text-white/20 sm:mb-8">
          Redo att börja?
        </div>
        <h2 class="mb-6 text-4xl font-medium leading-[0.92] tracking-[-0.05em] text-white/90 sm:text-5xl lg:mb-8 lg:text-7xl xl:text-[82px]">
          Sluta missa leads. <br/>
          <span class="text-white/20">Börja automatisera.</span>
        </h2>
        <p class="mx-auto mb-10 max-w-2xl text-base font-medium leading-relaxed text-white/30 sm:text-lg lg:mb-0 lg:text-xl">
          Gör som hundratals andra företag och bygg din egen autonoma AI-arbetsstyrka på några minuter. 
          <span class="text-white/60">Gratis i 14 dagar.</span>
        </p>
      </div>

      <div class="mx-auto mt-10 flex max-w-md flex-col items-stretch gap-4 sm:mt-12 sm:flex-row sm:items-center sm:max-w-none sm:justify-center" data-scene-visual>
        <button 
          type="button"
          onclick="window.openAgenter()"
          class="group relative w-full overflow-hidden rounded-full bg-white pl-8 pr-2 py-2 text-[10px] font-bold uppercase tracking-[0.2em] text-black shadow-[0_30px_60px_rgba(255,255,255,0.05)] transition-all ease-[cubic-bezier(0.32,0.72,0,1)] duration-700 active:scale-[0.98] sm:w-auto"
        >
          <span class="relative z-10 flex items-center justify-between gap-6">
            Boka demo nu
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-black/5 transition-transform duration-700 ease-[cubic-bezier(0.32,0.72,0,1)] group-hover:scale-105 group-hover:translate-x-1 group-hover:-translate-y-[1px]">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </div>
          </span>
        </button>
        <a href="#funktioner" class="w-full rounded-full border border-white/10 bg-transparent px-8 py-5 text-center text-[10px] font-bold uppercase tracking-[0.2em] text-white/40 transition-all ease-[cubic-bezier(0.32,0.72,0,1)] duration-700 hover:bg-white/5 hover:text-white active:scale-[0.98] sm:w-auto">
          Läs mer om funktioner
        </a>
      </div>
      <div class="mt-4 text-center text-[9px] font-bold uppercase tracking-[0.4em] text-white/10 sm:mt-6">
        Ta steget in i framtiden idag
      </div>
      </div>
    </div>
  </div>
</section>
