---
interface Props {
  lang?: 'en' | 'sv';
}
const { lang = 'en' } = Astro.props;

const copy = {
  label: lang === 'sv' ? 'Plattformen' : 'Platform',
  title: lang === 'sv' ? 'Bygg din AI-agent utan utveckling.' : 'Build your AI agent without development.',
  p1: lang === 'sv' 
    ? 'AgenterGroup är byggt för företag som vill äga sin AI-agent själva. Skapa en agent, lägg in kunskap, testa svaren och publicera den direkt på hemsidan.'
    : 'AgenterGroup is built for companies that want to own their AI agent themselves. Create an agent, add knowledge, test responses, and publish it directly on your website.',
  p2: lang === 'sv'
    ? 'Du behöver inte vänta på ett projekt för att komma igång. Plattformen ger er verktygen för kundtjänst, leadkvalificering, mötesbokning och löpande förbättring i samma arbetsyta.'
    : 'You do not need to wait for a project to get started. The platform gives your team tools for support, lead qualification, meeting booking, and continuous improvement in one workspace.',
  stats: [
    { label: lang === 'sv' ? 'Milj.' : 'Million', value: '5+', sub: lang === 'sv' ? 'Hanterade interaktioner' : 'Interactions handled' },
    { label: lang === 'sv' ? 'Timmar' : 'Hours', value: '100+', sub: lang === 'sv' ? 'Sparad arbetstid' : 'Time saved for clients' },
  ]
};
---

<section class="relative overflow-hidden bg-white py-24 px-6 md:py-32 lg:py-40 border-t border-slate-100">
  <!-- Premium ambient glows — corners -->
  <div class="glow-top-left"></div>
  <div class="glow-bottom-right"></div>
  <div class="pointer-events-none absolute right-0 top-0 w-96 h-96 bg-[radial-gradient(circle,_rgba(223,80,7,0.015),_transparent_70%)] blur-3xl"></div>
  <!-- Edge fades for smooth dark-light-dark transitions -->
  <div class="edge-fade-to-dark"></div>

  <div class="max-w-7xl mx-auto flex flex-col lg:flex-row gap-16 lg:gap-24 items-center relative z-10">
    
    <!-- Left: Content -->
    <div class="lg:w-1/2 text-left">
      <div class="reveal-wrapper mb-6 inline-flex items-center gap-3 rounded-full border border-slate-200 bg-slate-50 px-3.5 py-1.5 text-[8px] font-bold uppercase tracking-[0.28em] text-slate-400 sm:mb-8 sm:text-[9px] sm:tracking-[0.4em]">
        <span class="h-1.5 w-1.5 rounded-full bg-brand-orange"></span>
        {copy.label}
      </div>
      
      <h2 class="reveal-wrapper text-[clamp(2.25rem,6vw,4.5rem)] font-medium leading-[1.0] tracking-[-0.04em] text-slate-900 mb-8 max-w-[20ch]" style="transition-delay: 100ms;">
        {copy.title}
      </h2>
      
      <div class="reveal-wrapper space-y-6 text-[15px] md:text-[17px] font-medium leading-relaxed text-slate-500" style="transition-delay: 200ms;">
        <p class="hover:text-slate-800 transition-colors duration-500 ease-out">{copy.p1}</p>
        <p class="hover:text-slate-800 transition-colors duration-500 ease-out">{copy.p2}</p>
      </div>
    </div>

    <!-- Right: Visual/Stats -->
    <div class="lg:w-1/2 w-full grid grid-cols-2 gap-6 md:gap-8 items-start">
      {copy.stats.map((stat, idx) => (
        <div class="reveal-wrapper h-full" style={`transition-delay: ${idx * 150 + 300}ms`}>
          <div 
            class:list={[
              "about-stat-item group bg-slate-50/50 backdrop-blur-sm border border-slate-200/60 hover:border-brand-orange/30 rounded-[1.5rem] p-6 md:p-8 transition-all duration-700 hover:scale-[1.02] hover:shadow-[0_20px_50px_rgba(223,80,7,0.04)] hover:bg-white h-full flex flex-col justify-center",
              idx === 1 ? "translate-y-6 md:translate-y-12" : ""
            ]}
          >
            <div class="mb-5 flex items-center justify-between">
              <span class="text-[9px] font-bold uppercase tracking-[0.22em] text-slate-400 group-hover:text-slate-600 transition-colors duration-700">
                {stat.label}
              </span>
              <div class="h-1.5 w-1.5 rounded-full bg-brand-orange shadow-[0_0_8px_rgba(223,80,7,0.3)] group-hover:scale-125 transition-transform duration-700"></div>
            </div>
            
            <div class="about-stat-value text-5xl md:text-[68px] font-bold tracking-[-0.05em] text-brand-orange mb-3 group-hover:text-orange-600 transition-colors duration-700 leading-none" data-value={stat.value}>
              {stat.value}
            </div>
            
            <div class="text-[13px] md:text-[14px] font-semibold text-slate-500 group-hover:text-slate-800 transition-colors duration-700 leading-snug">
              {stat.sub}
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .reveal-wrapper {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 1s cubic-bezier(0.16, 1, 0.3, 1), transform 1s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal-wrapper.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  function initAboutStatsAnimation() {
    function animateValue(obj: Element, start: number, end: number, duration: number, prefix = '', suffix = '', decimals = 0) {
      let startTimestamp: number | null = null;
      const step = (timestamp: number) => {
        if (!startTimestamp) startTimestamp = timestamp;
        const progress = Math.min((timestamp - startTimestamp) / duration, 1);
        
        const easeOut = progress === 1 ? 1 : 1 - Math.pow(2, -10 * progress);
        const currentVal = easeOut * (end - start) + start;
        const formattedVal = decimals > 0 ? currentVal.toFixed(decimals) : Math.floor(currentVal).toString();
        
        obj.innerHTML = prefix + formattedVal + suffix;
        
        if (progress < 1) {
          window.requestAnimationFrame(step);
        } else {
          obj.innerHTML = prefix + end + suffix;
        }
      };
      window.requestAnimationFrame(step);
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const itemEl = entry.target;
          if (itemEl.classList.contains('animated')) return;
          
          itemEl.classList.add('animated');
          
          const valEl = itemEl.querySelector('.about-stat-value');
          if (valEl) {
            const finalValueStr = valEl.getAttribute('data-value');
            if (!finalValueStr) return;
            let prefix = '';
            let suffix = '';
            let numStr = finalValueStr;
            
            if (numStr.startsWith('+')) {
              prefix = '+';
              numStr = numStr.substring(1);
            }
            
            if (numStr.endsWith('%')) {
              suffix = '%';
              numStr = numStr.substring(0, numStr.length - 1);
            } else if (numStr.endsWith('M+')) {
              suffix = 'M+';
              numStr = numStr.substring(0, numStr.length - 2);
            } else if (numStr.endsWith('+')) {
              suffix = '+';
              numStr = numStr.substring(0, numStr.length - 1);
            }
            
            const endValue = parseInt(numStr, 10);
            
            if (!isNaN(endValue)) {
              const decimals = endValue < 10 ? 1 : 0;
              // Delay the stat counter animation slightly so it finishes after the fade in
              setTimeout(() => {
                animateValue(valEl, 0, endValue, 2000, prefix, suffix, decimals);
              }, 600);
            }
          }
          
          observer.unobserve(itemEl);
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.about-stat-item').forEach((el) => {
      observer.observe(el);
    });

    // Reveal animation observer
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          revealObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.reveal-wrapper').forEach((el) => {
      revealObserver.observe(el);
    });
  }

  // Run immediately for initial load
  initAboutStatsAnimation();
  // Support for Astro View Transitions if enabled
  document.addEventListener('astro:page-load', initAboutStatsAnimation);
</script>
