---
interface LinkCard {
  href: string;
  title: string;
  description: string;
}

interface Props {
  cards: readonly LinkCard[];
}

const { cards } = Astro.props as Props;
---

<section class="relative border-t border-white/[0.03] py-18 sm:py-24 lg:py-28">
  <div class="mx-auto w-full max-w-7xl px-4 sm:px-8 lg:px-10">
    <div class="mb-12 max-w-3xl sm:mb-14 lg:mb-16">
      <div class="mb-5 inline-flex items-center gap-3 rounded-full border border-white/10 bg-white/5 px-3 py-1 text-[8px] font-bold uppercase tracking-[0.28em] text-white/20 sm:text-[9px] sm:tracking-[0.4em]">
        Utforska sidorna
      </div>
      <h2 class="mb-5 max-w-[12ch] text-[clamp(2.75rem,11vw,5.25rem)] font-medium leading-[0.92] tracking-[-0.05em] text-white/90">
        Utforska rätt <br class="hidden sm:block" />
        <span class="text-white/20">lösning först.</span>
      </h2>
      <p class="max-w-2xl text-sm font-medium leading-relaxed text-white/35 sm:text-lg">
        Här är de viktigaste sidorna för företag som söker AI chatbot, AI agent, kundserviceautomation,
        leadkvalificering eller mötesbokning på svenska.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3">
      {cards.map((card) => (
        <a
          href={card.href}
          class="group glass-outer block transition-transform duration-500 ease-[cubic-bezier(0.32,0.72,0,1)] hover:-translate-y-1"
        >
          <div class="glass-inner flex h-full flex-col justify-between gap-8 p-8 sm:p-10">
            <div>
              <p class="mb-4 text-[9px] font-bold uppercase tracking-[0.34em] text-brand-orange/60">
                Sida
              </p>
              <h3 class="mb-4 text-2xl font-medium tracking-[-0.04em] text-white/88">
                {card.title}
              </h3>
              <p class="text-sm font-medium leading-relaxed text-white/35">
                {card.description}
              </p>
            </div>
            <span class="inline-flex items-center gap-3 text-[10px] font-bold uppercase tracking-[0.2em] text-white/55 transition-colors duration-300 group-hover:text-white">
              Läs mer
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14" />
                <path d="m12 5 7 7-7 7" />
              </svg>
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
