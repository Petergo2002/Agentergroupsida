---
interface Props {
  lang?: 'en' | 'sv';
}
const { lang = 'en' } = Astro.props;

const homeHref = lang === 'sv' ? '/sv/' : '/';
const navLinks = [
  { name: lang === 'sv' ? 'Hem' : 'Home', href: homeHref },
  { name: lang === 'sv' ? 'Funktioner' : 'Features', href: `${homeHref}#services` },
  { name: lang === 'sv' ? 'Priser' : 'Pricing', href: `${homeHref}#pricing` },
  { name: lang === 'sv' ? 'Kontakt' : 'Contact', href: `${homeHref}#contact` }
];

const loginText = lang === 'sv' ? 'Logga in' : 'Log in';
const demoText = lang === 'sv' ? 'Boka en demo' : 'Book a Demo';
---

<header class="fixed top-0 inset-x-0 z-50 bg-[#0C0C0C]/95 backdrop-blur-md border-b border-white/10 h-16 md:h-20 flex items-center overflow-visible">
  <div class="max-w-7xl w-full mx-auto px-6 flex items-center justify-between overflow-visible">
    <!-- Logo -->
    <a href={homeHref} class="flex items-center gap-2 group relative z-10 overflow-visible">
      <img src="/Logotransparant.svg" alt="Agentergroup Logo" class="h-[116px] md:h-[148px] w-auto transition-transform duration-300 ease-out hover:scale-105" />
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <a 
          href={link.href} 
          class="text-sm font-medium text-slate-300 hover:text-white transition-colors"
        >
          {link.name}
        </a>
      ))}
    </nav>

    <!-- Actions -->
    <div class="hidden md:flex items-center gap-4">
      <a href="https://dashboard.agentergroup.com/login" class="text-sm font-medium text-slate-300 hover:text-white transition-colors">
        {loginText}
      </a>
      <a
        href={`${homeHref}#contact`}
        class="text-sm font-semibold text-white bg-brand-orange hover:bg-orange-600 px-5 py-2.5 rounded-full transition-colors shadow-sm shadow-brand-orange/20 text-center"
      >
        {demoText}
      </a>
    </div>

    <!-- Mobile Menu Button -->
    <button class="md:hidden p-2 text-slate-300 hover:text-white" type="button" aria-label="Menu" aria-expanded="false" aria-controls="mobile-menu" data-mobile-menu-button>
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="hidden border-t border-white/10 bg-[#0C0C0C] px-6 pb-6 md:hidden" data-mobile-menu>
    <nav class="flex flex-col gap-1 py-4">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="rounded-lg px-3 py-3 text-sm font-semibold text-slate-300 hover:bg-white/5 hover:text-white"
          data-mobile-menu-link
        >
          {link.name}
        </a>
      ))}
    </nav>
    <div class="flex flex-col gap-3">
      <a href="https://dashboard.agentergroup.com/login" class="rounded-lg px-3 py-3 text-sm font-semibold text-slate-300 hover:bg-white/5 hover:text-white">
        {loginText}
      </a>
      <a
        href={`${homeHref}#contact`}
        class="rounded-full bg-brand-orange px-5 py-3 text-sm font-semibold text-white shadow-sm shadow-brand-orange/20 hover:bg-orange-600 text-center font-bold"
      >
        {demoText}
      </a>
    </div>
  </div>
</header>

<script>
  const menuButton = document.querySelector('[data-mobile-menu-button]');
  const mobileMenu = document.querySelector('[data-mobile-menu]');
  const menuLinks = document.querySelectorAll('[data-mobile-menu-link]');

  function closeMobileMenu() {
    mobileMenu?.classList.add('hidden');
    menuButton?.setAttribute('aria-expanded', 'false');
  }

  menuButton?.addEventListener('click', () => {
    const isOpen = menuButton.getAttribute('aria-expanded') === 'true';
    mobileMenu?.classList.toggle('hidden', isOpen);
    menuButton.setAttribute('aria-expanded', String(!isOpen));
  });

  menuLinks.forEach((link) => {
    link.addEventListener('click', closeMobileMenu);
  });
</script>
