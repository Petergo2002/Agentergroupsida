---
import { SITE_NAME } from '../data/site';

interface Props {
  lang?: 'en' | 'sv';
}
const { lang = 'en' } = Astro.props;

const copy = {
  rights: lang === 'sv' ? 'Alla rättigheter förbehållna.' : 'All rights reserved.',
  company: 'AgenterGroup',
  address: 'Borås, Sweden',
  tagline: lang === 'sv' ? 'Bygger nästa generations AI-agenter och automationer för framåtblickande företag.' : 'Building next-generation AI agents and automations for forward-thinking businesses.',
  links: [
    { name: lang === 'sv' ? 'Sekretesspolicy' : 'Privacy Policy', href: '/privacy' },
    { name: lang === 'sv' ? 'Användarvillkor' : 'Terms of Service', href: '/terms' },
    { name: lang === 'sv' ? 'Kontakta oss' : 'Contact Us', href: 'mailto:info@agentergroup.com' }
  ]
};
---

<footer id="contact" class="relative overflow-hidden bg-[#0C0C0C] border-t border-white/10 py-16 px-6">
  <div class="glow-dark-top-right"></div>
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center md:items-start gap-12 relative z-10">
    
    <div class="flex flex-col items-center md:items-start gap-4">
      <div class="flex items-center">
        <img src="/Logotransparant.svg" alt="Agentergroup Logo" class="h-[116px] md:h-[148px] w-auto transition-transform duration-300 ease-out hover:scale-105" />
      </div>
      <p class="text-slate-400 text-sm mt-1 text-center md:text-left max-w-[280px] leading-relaxed">
        {copy.tagline}
      </p>
      <div class="flex items-center gap-2 text-slate-400 text-sm mt-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/>
          <circle cx="12" cy="10" r="3"/>
        </svg>
        <span class="font-medium">{copy.address}</span>
      </div>
    </div>

    <div class="flex flex-col items-center md:items-end justify-between h-full gap-8 md:pt-2">
      <div class="flex flex-wrap justify-center md:justify-end gap-x-8 gap-y-4">
        {copy.links.map(link => (
          <a href={link.href} class="text-sm font-semibold text-slate-400 hover:text-white transition-colors">
            {link.name}
          </a>
        ))}
      </div>
      <p class="text-slate-500 text-sm text-center md:text-right mt-4 md:mt-8">
        &copy; {new Date().getFullYear()} {SITE_NAME}. {copy.rights}
      </p>
    </div>

  </div>
</footer>
