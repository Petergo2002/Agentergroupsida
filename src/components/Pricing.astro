---
import { DASHBOARD_SIGNUP_URL } from "../data/site";

interface Props {
  lang?: 'en' | 'sv';
}

const { lang = 'en' } = Astro.props;

const content = {
  en: {
    badge: "Pricing",
    title: "Start free.",
    titleSuffix: "Upgrade when it works.",
    description: "Choose the plan that matches your current volume. Start with the free workspace, test the widget on your site, and scale when the dialogs become part of your workflow.",
    monthly: "/mo",
    plans: [
      {
        name: "Free",
        description: "Free forever. Basic features for individuals.",
        price: "$0",
        cta: "START FREE",
        features: [
          "1 workspace",
          "1 widget",
          "50 messages per month",
          "1 active agent",
          "0 team members",
          "10 MB Knowledge Base storage",
          "Community support",
        ],
      },
      {
        name: "Starter",
        description: "Enhanced features for growing businesses",
        price: "$30",
        cta: "CHOOSE STARTER",
        features: [
          "1 workspace",
          "Up to 3 widgets",
          "500 messages per month",
          "Up to 3 agents",
          "Up to 2 team members",
          "25 MB Knowledge Base storage",
          "Full integrations",
          "Priority support",
        ],
      },
      {
        name: "Premium",
        description: "Advanced features for high volume",
        price: "$110",
        cta: "CHOOSE PREMIUM",
        highlighted: true,
        features: [
          "Up to 5 workspaces",
          "Up to 6 widgets",
          "4000 messages per month",
          "Unlimited agents",
          "Up to 10 team members",
          "50 MB Knowledge Base storage",
          "Full integrations",
          "Remove widget branding",
          "Dedicated support",
        ],
      },
    ],
  },
  sv: {
    badge: "Priser",
    title: "Börja gratis.",
    titleSuffix: "Uppgradera när det fungerar.",
    description: "Välj planen som matchar er volym just nu. Starta med en gratis workspace, testa widgeten på riktigt och skala upp när dialogerna börjar bli en del av flödet.",
    monthly: "/mån",
    plans: [
      {
        name: "Free",
        description: "Gratis för alltid. Grundläggande funktioner för enskilda.",
        price: "$0",
        cta: "BÖRJA GRATIS",
        features: [
          "1 workspace",
          "1 widget",
          "50 meddelanden per månad",
          "1 aktiv agent",
          "0 teammedlemmar",
          "10 MB Knowledge Base-lagring",
          "Community-support",
        ],
      },
      {
        name: "Starter",
        description: "Utökade funktioner för växande företag",
        price: "$30",
        cta: "VÄLJ STARTER",
        features: [
          "1 workspace",
          "Upp till 3 widgets",
          "500 meddelanden per månad",
          "Upp till 3 agenter",
          "Upp till 2 teammedlemmar",
          "25 MB Knowledge Base-lagring",
          "Fulla integrationer",
          "Prioriterad support",
        ],
      },
      {
        name: "Premium",
        description: "Avancerade funktioner för hög volym",
        price: "$110",
        cta: "VÄLJ PREMIUM",
        highlighted: true,
        features: [
          "Upp till 5 workspaces",
          "Upp till 6 widgets",
          "4000 meddelanden per månad",
          "Obegränsat antal agenter",
          "Upp till 10 teammedlemmar",
          "50 MB Knowledge Base-lagring",
          "Fulla integrationer",
          "Ta bort widget-branding",
          "Dedikerad support",
        ],
      },
    ],
  }
}[lang];
---

<section
  id="pricing"
  class="scroll-scene relative bg-[#050505] text-white py-20 sm:py-32 lg:py-40 px-6"
  data-scroll-scene
  data-scene-kind="pricing"
  data-scene-mode="soft"
>
  <!-- Elegant fading accent line divider -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-5xl h-px bg-gradient-to-r from-transparent via-white/[0.08] to-transparent z-10"></div>

  <div class="scene-divider" data-scene-divider></div>
  <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px] bg-[radial-gradient(circle_at_top,_rgba(255,92,0,0.06),_transparent_75%)]" data-scene-backdrop></div>
  <div class="glow-dark-bottom-left"></div>
  
  <div class="mx-auto w-full max-w-7xl relative z-10" data-scene-stage>
    <!-- Header -->
    <div class="mb-12 grid gap-8 text-left sm:mb-16 lg:mb-20 lg:grid-cols-[minmax(0,0.95fr)_minmax(20rem,0.65fr)] lg:items-end" data-scene-content>
      <div>
      <div class="mb-6 inline-flex items-center gap-3 rounded-full border border-white/10 bg-white/5 px-3 py-1 text-[8px] font-bold uppercase tracking-[0.28em] text-white/20 sm:mb-8 sm:text-[9px] sm:tracking-[0.4em]">
        {content.badge}
      </div>
      <h2 class="max-w-[13ch] text-[clamp(2.25rem,6vw,4.5rem)] font-medium leading-[1.0] tracking-[-0.04em] text-white/90">
        {content.title} <span class="text-white/20">{content.titleSuffix}</span>
      </h2>
      </div>
      <p class="max-w-xl text-sm font-medium leading-relaxed text-white/40 sm:text-base md:text-[17px] lg:text-lg">
        {content.description}
      </p>
    </div>

    <!-- Plans -->
    <div class="grid gap-4 md:grid-cols-3 lg:gap-5" data-scene-visual>
      {content.plans.map((plan) => (
        <article
          class:list={[
            "group relative flex min-h-[35rem] flex-col overflow-hidden rounded-[1.5rem] p-6 sm:p-8 lg:p-9",
            plan.highlighted
              ? "border border-brand-orange bg-[#0F0F0F]"
              : "border border-white/[0.03] bg-[#0F0F0F]",
          ]}
        >
          <div class="mb-8 pr-12">
            <h3 class="mb-2 text-[26px] font-bold tracking-tight text-white/90 sm:text-[28px]">
              {plan.name}
            </h3>
            <p class="min-h-[3rem] text-[15px] font-medium leading-relaxed text-white/40">
              {plan.description}
            </p>
          </div>

          <div class="mb-10 flex items-baseline gap-1">
            <span class="text-[40px] font-bold tracking-[-0.04em] text-white sm:text-[44px]">
              {plan.price}
            </span>
            <span class="text-[15px] font-medium text-white/40">
              {content.monthly}
            </span>
          </div>

          <ul class="mb-10 flex flex-1 flex-col gap-4">
            {plan.features.map((feature) => (
              <li class="flex items-start gap-3 text-[14px] font-medium leading-relaxed text-white/60">
                <span class="mt-[3px] flex shrink-0 items-center justify-center text-brand-orange">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 6 9 17l-5-5"></path>
                  </svg>
                </span>
                <span>{feature}</span>
              </li>
            ))}
          </ul>

          <a
            href={DASHBOARD_SIGNUP_URL}
            class="mt-auto inline-flex h-[48px] w-full items-center justify-center rounded-full bg-white/[0.06] px-5 text-center text-[11px] font-bold uppercase tracking-[0.08em] text-white/80 transition-colors hover:bg-white/10 active:scale-[0.98]"
          >
            {plan.cta}
          </a>
        </article>
      ))}
    </div>
  </div>
</section>
