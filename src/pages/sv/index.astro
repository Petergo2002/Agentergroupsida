---
import Layout from '../../layouts/Layout.astro';
import HeroSection from '../../components/HeroSection.astro';
import StatsGrid from '../../components/StatsGrid.astro';
import ServicesGrid from '../../components/ServicesGrid.astro';
import AboutUs from '../../components/AboutUs.astro';
import TargetAudience from '../../components/TargetAudience.astro';
import Pricing from '../../components/Pricing.astro';
import ContactSection from '../../components/ContactSection.astro';
import { SITE_URL, SITE_NAME } from '../../data/site';

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: "AI chatbot för företag i Sverige | AgenterGroup",
    description: "Vi bygger AI-agenter och AI-chatbots för svenska företag inom kundservice, leadkvalificering och mötesbokning.",
    url: `${SITE_URL}/sv/`,
    inLanguage: "sv-SE",
  },
];
---

<Layout
  lang="sv"
  title={`AI Chatbots & Agenter för Företag | ${SITE_NAME}`}
  description="Hantera kundfrågor, kvalificera leads och boka möten – allt från en smart och intuitiv plattform."
  canonicalPath="/sv/"
  alternateLinks={[
    { hreflang: "en", href: "/" },
    { hreflang: "sv", href: "/sv/" },
    { hreflang: "x-default", href: "/" },
  ]}
  structuredData={structuredData}
>
  <HeroSection lang="sv" />
  <StatsGrid lang="sv" />
  <ServicesGrid lang="sv" />
  <AboutUs lang="sv" />
  <TargetAudience lang="sv" />
  <Pricing lang="sv" />
  <ContactSection lang="sv" />
</Layout>
