---
import Layout from "../../layouts/Layout.astro";
import ServicePageTemplate from "../../components/ServicePageTemplate.astro";
import { SITE_URL } from "../../data/site";

const title = "Hemsida med AI agent för fler leads | AgenterGroup";
const description =
  "Lägg till en AI agent på hemsidan med AgenterGroup. Skapa agenten, träna den på ert innehåll och fånga leads direkt från webbplatsen.";

const faqs = [
  {
    question: "Är det här en hemsida eller ett AI agent-projekt?",
    answer:
      "Det handlar om att göra hemsidan mer aktiv. Ni installerar en AI-agent som kan svara, kvalificera besökare och leda dem vidare till kontakt eller bokning.",
  },
  {
    question: "Fungerar det på en befintlig hemsida?",
    answer:
      "Ja. AgenterGroups AI agent kan användas på en befintlig hemsida så att ni snabbt kan testa den utan att börja om från noll.",
  },
  {
    question: "Vad gör AI-agenten på hemsidan?",
    answer:
      "AI-agenten kan svara på vanliga frågor, kvalificera besökare, samla kontaktuppgifter, skicka vidare leads och leda rätt personer mot ett bokat möte.",
  },
  {
    question: "Måste vi själva sätta upp AI-flöden och prompts?",
    answer:
      "Ni kan skapa agenten själva i plattformen genom att lägga in kunskap, instruktioner och mål. Det är byggt för att vara enkelt även utan kod.",
  },
];

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: title,
    description,
    url: `${SITE_URL}/sv/hemsida-med-ai-chatbot`,
    inLanguage: "sv-SE",
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    serviceType: "Hemsida med AI agent",
    name: "Hemsida med AI agent",
    provider: {
      "@type": "Organization",
      name: "AgenterGroup",
      url: SITE_URL,
    },
    areaServed: "SE",
    availableLanguage: "sv-SE",
    audience: {
      "@type": "BusinessAudience",
      audienceType: "Svenska B2B- och tjänsteföretag",
    },
    description,
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((faq) => ({
      "@type": "Question",
      name: faq.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: faq.answer,
      },
    })),
  },
];
---

<Layout
  lang="sv"
  title={title}
  description={description}
  canonicalPath="/sv/hemsida-med-ai-chatbot"
  alternateLinks={[
    { hreflang: "sv", href: "/sv/hemsida-med-ai-chatbot" },
    { hreflang: "x-default", href: "/sv/hemsida-med-ai-chatbot" },
  ]}
  structuredData={structuredData}
>
  <ServicePageTemplate
    lang="sv"
    badge="Hemsida + AI agent"
    title="Gör hemsidan säljande med egen AI-agent"
    description="Skapa en AI agent i AgenterGroup, publicera den på hemsidan och låt den svara direkt, fånga leads och leda rätt personer till bokning."
    secondaryHref="/"
    secondaryLabel="Till startsidan"
    stats={[
      { label: "Primärt mål", value: "Fler kvalificerade leads" },
      { label: "Byggt runt", value: "Agent, kunskap och flöden" },
      { label: "Passar för", value: "Tjänsteföretag och B2B" },
    ]}
    blocks={[
      {
        title: "Hemsida och AI agent som ett system",
        body: "En bra hemsida ska inte lämna varje besökare vid ett statiskt kontaktformulär. Med AI-agenten kan ni lägga till en aktiv dialog som svarar samtidigt som ni fångar rätt information.",
        bullets: [
          "Träna agenten på era tjänster, frågor och dokument",
          "AI-agentflöden som svarar på frågor och kvalificerar behov",
          "Call to actions som leder mot kontakt eller bokning",
        ],
      },
      {
        title: "Varför en vanlig hemsida inte räcker",
        body: "Många hemsidor ser okej ut men tappar köpare eftersom nästa steg är otydligt. En AI agent ger besökaren ett direkt sätt att fråga, jämföra och agera utan att vänta på manuellt svar.",
        bullets: [
          "Ersätt passiva formulär med aktiva konversationer",
          "Fånga frågor som annars försvinner",
          "Guida varma besökare medan de fortfarande är på sidan",
        ],
      },
      {
        title: "Det ni skapar i AgenterGroup",
        body: "I plattformen skapar ni agenten, lägger in kunskap, styr tonen, aktiverar lead capture och publicerar den så att hemsidan fungerar som en säljresurs.",
        bullets: [
          "Kunskapsbas med webbplats, dokument och FAQ",
          "Agent-regler för kvalificering och överlämning",
          "Boknings- och leadflöden kopplade till er säljprocess",
        ],
      },
      {
        title: "Vilka det passar för",
        body: "Det här passar företag som säljer genom förtroende, förklaring och timing. Om era kunder behöver svar innan de kontaktar er kan hemsidan och AI-agenten arbeta tillsammans.",
        bullets: [
          "Lokala tjänsteföretag och konsulter",
          "B2B-team som vill höja leadkvaliteten",
          "Företag som vill ersätta långsamma formulär och manuell uppföljning",
        ],
      },
    ]}
    faqs={faqs}
    relatedLinks={[
      { href: "/sv/ai-chatbot-foretag", title: "AI agent för företag" },
      { href: "/sv/ai-kundtjanst", title: "AI-kundtjänst" },
      { href: "/sv/blogg", title: "Blogg" },
    ]}
  />
</Layout>
