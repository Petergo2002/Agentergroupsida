---
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/HeroSection.astro';
import StatsGrid from '../components/StatsGrid.astro';
import ServicesGrid from '../components/ServicesGrid.astro';
import AboutUs from '../components/AboutUs.astro';
import TargetAudience from '../components/TargetAudience.astro';
import Pricing from '../components/Pricing.astro';
import ContactSection from '../components/ContactSection.astro';
import { SITE_URL, SITE_NAME } from '../data/site';

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: "AI Agent for Business | AgenterGroup",
    description: "AgenterGroup is a SaaS platform where companies create, train, and launch their own AI agents for customer service, lead qualification, and meeting booking.",
    url: `${SITE_URL}/`,
    inLanguage: "en-US",
  },
];
---

<Layout
  lang="en"
  title={`Create Your Own AI Agent | ${SITE_NAME}`}
  description="Create, train, and launch your own AI agent for customer service, lead qualification, and meeting booking from one SaaS platform."
  canonicalPath="/"
  alternateLinks={[
    { hreflang: "en", href: "/" },
    { hreflang: "sv", href: "/sv/" },
    { hreflang: "x-default", href: "/" },
  ]}
  structuredData={structuredData}
>
  <HeroSection lang="en" />
  <StatsGrid lang="en" />
  <ServicesGrid lang="en" />
  <AboutUs lang="en" />
  <TargetAudience lang="en" />
  <Pricing lang="en" />
  <ContactSection lang="en" />
</Layout>
