---
import Layout from "../layouts/Layout.astro";
import ServicePageTemplate from "../components/ServicePageTemplate.astro";
import { SITE_URL } from "../data/site";

const title = "AI mötesbokning | AgenterGroup";
const description =
  "Automatisera mötesbokning med AI. Låt agenten boka möten direkt i kalendern efter att dialogen har kvalificerats.";

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: title,
    description,
    url: `${SITE_URL}/ai-motesbokning`,
    inLanguage: "sv-SE",
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    serviceType: "AI mötesbokning",
    provider: { "@type": "Organization", name: "AgenterGroup", url: SITE_URL },
    areaServed: "SE",
    availableLanguage: "sv-SE",
    description,
  },
];
---

<Layout title={title} description={description} canonicalPath="/ai-motesbokning" structuredData={structuredData}>
  <ServicePageTemplate
    badge="AI mötesbokning"
    title="AI för mötesbokning utan manuell ping pong"
    description="När en dialog är rätt kvalificerad ska den inte fastna i inboxen. Vår AI agent kan gå hela vägen till bokat möte genom att kopplas till kalender och interna processer."
    stats={[
      { label: "Primär effekt", value: "Kortare väg till bokat möte" },
      { label: "Koppling", value: "Kalender och processer" },
      { label: "Resultat", value: "Mindre friktion i säljarbetet" },
    ]}
    blocks={[
      {
        title: "Från intresse till bokning",
        body: "Många leads tappar fart mellan första kontakt och faktisk bokning. Agenten hjälper till att hålla tempot genom att kvalificera, föreslå nästa steg och boka när leadet är redo.",
        bullets: [
          "Kvalificera först, boka sen",
          "Undvik onödig manuell uppföljning",
          "Minska tapp mellan dialog och möte",
        ],
      },
      {
        title: "När use caset fungerar som bäst",
        body: "AI mötesbokning fungerar särskilt bra när ni har återkommande inkommande förfrågningar, tydliga mötestyper och behov av snabb återkoppling.",
        bullets: [
          "Inbound-dialoger från hemsidan",
          "Säljflöden där snabbhet avgör",
          "Team som vill fokusera på samtal i stället för koordinering",
        ],
      },
    ]}
    faqs={[
      {
        question: "Kan agenten boka direkt i kalendern?",
        answer: "Ja, om vi kopplar lösningen till er kalender och definierar hur bokningslogiken ska fungera.",
      },
      {
        question: "Måste leadet kvalificeras först?",
        answer: "Det är ofta bäst. Då bokas bara möten som uppfyller rätt kriterier och som är värda tiden.",
      },
      {
        question: "Kan ni styra vilken typ av möten som ska bokas?",
        answer: "Ja. Vi kan bygga olika regler för olika team, mötestyper eller segment.",
      },
      {
        question: "Kan detta kombineras med leadkvalificering?",
        answer: "Ja. Det är en av de starkaste kombinationerna eftersom bokning blir ett naturligt nästa steg efter kvalificering.",
      },
    ]}
    relatedLinks={[
      { href: "/ai-leadkvalificering", title: "AI leadkvalificering" },
      { href: "/ai-agent-kundservice", title: "AI agent för kundservice" },
      { href: "/sa-fungerar-det", title: "Så fungerar det" },
    ]}
  />
</Layout>
