---
import Layout from '../layouts/Layout.astro';
import { SITE_NAME } from '../data/site';

const title = `Privacy Policy | ${SITE_NAME}`;
const description = 'How AgenterGroup handles contact information, website analytics, and customer communication.';
---

<Layout
  lang="en"
  title={title}
  description={description}
  canonicalPath="/privacy"
  alternateLinks={[
    { hreflang: 'en', href: '/privacy' },
    { hreflang: 'x-default', href: '/privacy' },
  ]}
>
  <section class="bg-[#050505] px-6 pb-24 pt-32 text-white sm:pt-40">
    <div class="mx-auto max-w-3xl">
      <p class="mb-5 text-[10px] font-bold uppercase tracking-[0.24em] text-white/28">Legal</p>
      <h1 class="text-[clamp(2.6rem,8vw,4.5rem)] font-medium leading-[0.95] tracking-[-0.05em] text-white/92">
        Privacy Policy
      </h1>
      <div class="mt-10 space-y-8 text-sm font-medium leading-relaxed text-white/55 sm:text-base">
        <p>
          AgenterGroup uses personal information only to respond to inquiries, provide requested services, operate our website, and improve our customer communication.
        </p>
        <section>
          <h2 class="mb-3 text-2xl font-medium text-white/88">Information We Collect</h2>
          <p>
            We may collect contact details you submit, messages sent through our forms or chat widget, basic website analytics, and technical information needed to keep the site secure and reliable.
          </p>
        </section>
        <section>
          <h2 class="mb-3 text-2xl font-medium text-white/88">How We Use It</h2>
          <p>
            We use this information to answer questions, book meetings, deliver services, maintain integrations, and improve the quality of our website and AI workflows.
          </p>
        </section>
        <section>
          <h2 class="mb-3 text-2xl font-medium text-white/88">Contact</h2>
          <p>
            For privacy questions or data requests, contact us at <a class="text-brand-orange hover:text-orange-400" href="mailto:hello@agentergroup.com">hello@agentergroup.com</a>.
          </p>
        </section>
      </div>
    </div>
  </section>
</Layout>
